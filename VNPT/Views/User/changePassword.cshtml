@{
    ViewData["Title"] = "Đổi mật khẩu";
}

<div class="pagetitle">
    <h1>Đổi mật khẩu tài khoản</h1>
</div>

<section class="section">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card">
                <div class="card-body mt-3">
                    <h5 class="card-title text-center mb-4" style="padding:0;">Cập nhật mật khẩu mới</h5>

                    <form id="changePasswordForm" onsubmit="submitChangePassword(event)">
                        <div class="mb-3">
                            <label class="form-label">Mật khẩu hiện tại</label>
                            <input type="password" class="form-control" id="txtOldPassword" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Mật khẩu mới</label>
                            <input type="password" class="form-control" id="txtNewPassword" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Xác nhận mật khẩu mới</label>
                            <input type="password" class="form-control" id="txtConfirmPassword" required />
                            <small id="errorMatch" class="text-danger d-none">Mật khẩu xác nhận không trùng khớp!</small>
                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-4">
                            <a href="/Home/Index" class="btn btn-secondary">Hủy bỏ</a>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-shield-lock me-1"></i> Cập nhật
                            </button>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        function submitChangePassword(event) {
            event.preventDefault(); // Chặn việc reload trang mặc định của Form

            const oldPassword = document.getElementById('txtOldPassword').value;
            const newPassword = document.getElementById('txtNewPassword').value;
            const confirmPassword = document.getElementById('txtConfirmPassword').value;
            const errorMatch = document.getElementById('errorMatch');

            // 1. Kiểm tra xem mật khẩu mới và xác nhận mật khẩu có khớp nhau ở giao diện không
            if (newPassword !== confirmPassword) {
                errorMatch.classList.remove('d-none');
                return;
            } else {
                errorMatch.classList.add('d-none');
            }

            // 2. Tạo FormData tương thích với tham số của Backend API
            const formData = new FormData();
            formData.append('oldPassword', oldPassword);
            formData.append('newPassword', newPassword);

            // 3. Gọi API bằng Fetch
            fetch('/quan-ly-user/doi-mat-khau', {
                method: 'POST',
                body: formData
            })
            .then(res => res.json())
            .then(result => {
                if (result.success) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Thành công',
                        text: result.message,
                        timer: 2000,
                        showConfirmButton: false
                    }).then(() => {
                        // Đổi pass xong thành công thì đá về trang chủ
                        window.location.href = '/Home/Index';
                    });
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'Thất bại',
                        text: result.message
                    });
                    if (result.message.includes("Hết phiên")) {
                        window.location.href = '/Auth/Login';
                    }
                }
            })
            .catch(err => {
                console.error("Lỗi kết nối:", err);
                Swal.fire({ icon: 'error', title: 'Lỗi', text: 'Không thể kết nối đến máy chủ!' });
            });
        }
    </script>
}